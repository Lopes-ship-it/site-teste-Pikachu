# Copie este arquivo para ".env" e preencha com os dados do seu projeto Firebase
# (Firebase Console → Configurações do projeto → Seus apps → SDK setup and configuration).
#
# Este arquivo (.env.example) pode ficar no Git. O arquivo ".env" real NUNCA deve
# ser commitado — ele já está no .gitignore.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
